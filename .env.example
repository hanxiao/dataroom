# Jina API key — powers Jina MCP (search_web, read_url) exposed to the agent,
# and downloads jina-embeddings-v5-nano. Get one free at https://jina.ai/api-dashboard/
JINA_API_KEY=jina_xxxx

# Context window for the LLM (= llama-server --ctx-size, and the dashboard/compaction
# denominator). Default targets Qwen3.6's full 131072. Q3_K_XL (~17GB) + q8_0 KV cache
# fits a large window on the L4 24GB. Lower this (e.g. 65536) if you OOM.
# CTX_SIZE=131072

# Optional budgets per job
# MAX_TURNS=60
# MAX_SECONDS=10800
# TURN_TIMEOUT=1200
